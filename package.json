{
	"name": "js-library-browser",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"lint": "conc \"npm run lint:js\" \"npm run lint:html\" \"npm run lint:css\"",
		"lint:js": "npm run build -w @w0s/writing-mode && eslint packages/**/*.ts *.{js,mjs}",
		"lint:html": "markuplint packages/**/*.html",
		"lint:css": "stylelint -f verbose packages/**/*.html",
		"pretest": "npm run build -w @w0s/writing-mode && npm run build --workspaces",
		"test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest packages/.+?/dist/.+\\.test\\.js  -c jest.config.mjs"
	},
	"devDependencies": {
		"@w0s/eslint-config": "9.7.0",
		"@w0s/markuplint-config": "3.13.0",
		"@w0s/stylelint-config": "4.23.0",
		"@w0s/tsconfig": "3.0.0",
		"concurrently": "10.0.3",
		"coveralls": "3.1.1",
		"cross-env": "10.1.0",
		"cross-fetch": "4.1.0",
		"eslint": "9.39.4",
		"eslint-plugin-functional": "9.0.5",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-jsdoc": "62.9.0",
		"eslint-plugin-safely-storage": "1.1.0",
		"globals": "17.6.0",
		"http-server": "14.1.1",
		"jest": "30.4.2",
		"jest-environment-jsdom": "30.4.1",
		"jsdom-testing-mocks": "1.16.0",
		"postcss-html": "1.8.1",
		"prettier": "3.8.3",
		"rimraf": "6.1.3",
		"stylelint": "17.12.0",
		"stylelint-attribute-case-sensitivity": "3.0.1",
		"stylelint-config-concentric-order": "5.5.0",
		"stylelint-config-standard": "40.0.0",
		"stylelint-no-default-viewport": "2.0.1",
		"stylelint-root-colors": "3.0.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.0"
	}
}
