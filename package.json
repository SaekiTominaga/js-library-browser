{
	"name": "js-library-browser",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"lint": "conc \"npm run lint:js\" \"npm run lint:html\" \"npm run lint:css\"",
		"lint:js": "eslint packages/**/*.ts *.{js,mjs}",
		"lint:html": "markuplint packages/**/*.html",
		"lint:css": "stylelint -f verbose packages/**/*.html"
	},
	"devDependencies": {
		"@w0s/eslint-config": "9.5.1",
		"@w0s/markuplint-config": "3.13.0",
		"@w0s/stylelint-config": "4.19.1",
		"@w0s/tsconfig": "2.0.1",
		"concurrently": "9.2.1",
		"coveralls": "3.1.1",
		"cross-env": "10.1.0",
		"cross-fetch": "4.1.0",
		"globals": "17.3.0",
		"http-server": "14.1.1",
		"jest": "30.2.0",
		"jest-environment-jsdom": "30.2.0",
		"jsdom-testing-mocks": "1.16.0",
		"postcss-html": "1.8.1",
		"prettier": "3.8.1",
		"rimraf": "6.1.3",
		"typescript": "5.9.3"
	}
}
